#!/bin/bash

#SBATCH --partition=gpu_h100
#SBATCH --gres=gpu:1
#SBATCH --cpus-per-task=12
#SBATCH --mem=100G
#SBATCH --job-name=ds_r1_gen_probe
#SBATCH --ntasks=1
#SBATCH --time=24:00:00
#SBATCH --output=/home/dpereira/lrm_planning/work/deepseek_r1_qwen32b_probe_generation_%A.out

set -euo pipefail

module purge
module load 2025
module load Python/3.13.1-GCCcore-14.2.0
module load CUDA/12.8.0
source /home/dpereira/lrm_planning/env/bin/activate

REPO_ROOT=/home/dpereira/lrm_planning
cd "$REPO_ROOT"

# Override at submission time with:
# sbatch --export=ALL,MODEL_NAME=...,OUTPUT_DIR=... jobs/deepseek_r1_qwen32b_probe_generation.job
MODEL_NAME=${MODEL_NAME:-/scratch-shared/dpereira/deepseek-r1-qwen32b}
N_DISKS=${N_DISKS:-4}
GENERATED_TEXTS=${GENERATED_TEXTS:-outputs/deepseek_r1_qwen32b_probe/generated_texts.json}
LAYERS=${LAYERS:-24,36,48}
OUTPUT_DIR=${OUTPUT_DIR:-outputs/deepseek_r1_qwen32b_probe_generation}
DEVICE=${DEVICE:-cuda}
DTYPE=${DTYPE:-bfloat16}
EPOCHS=${EPOCHS:-2000}
LR=${LR:-1e-3}
SEED=${SEED:-42}

export PYTHONUNBUFFERED=1

SCRATCH_DIR=${SCRATCH_DIR:-/scratch-shared/dpereira}
mkdir -p "$SCRATCH_DIR"
export HF_HOME=${HF_HOME:-$SCRATCH_DIR/hf_cache}
export TRANSFORMERS_CACHE=${TRANSFORMERS_CACHE:-$SCRATCH_DIR/transformers}
export HF_DATASETS_CACHE=${HF_DATASETS_CACHE:-$SCRATCH_DIR/datasets}
export TORCH_HOME=${TORCH_HOME:-$SCRATCH_DIR/torch_cache}
export TRITON_CACHE_DIR=${TRITON_CACHE_DIR:-$SCRATCH_DIR/triton_cache}
export XDG_CACHE_HOME=${XDG_CACHE_HOME:-$SCRATCH_DIR/cache}
mkdir -p "$HF_HOME" "$TRANSFORMERS_CACHE" "$HF_DATASETS_CACHE" \
         "$TORCH_HOME" "$TRITON_CACHE_DIR" "$XDG_CACHE_HOME"

echo "========== DeepSeek-R1-Qwen32B Generation Probe =========="
echo "MODEL_NAME:       $MODEL_NAME"
echo "N_DISKS:          $N_DISKS"
echo "GENERATED_TEXTS:  $GENERATED_TEXTS"
echo "LAYERS:           $LAYERS"
echo "OUTPUT_DIR:       $OUTPUT_DIR"
echo "DEVICE:           $DEVICE"
echo "DTYPE:            $DTYPE"
echo "EPOCHS:           $EPOCHS"
echo "LR:               $LR"
echo "SEED:             $SEED"
echo "Python:           $(which python)"
python --version
echo "CUDA_VISIBLE_DEVICES: ${CUDA_VISIBLE_DEVICES:-unset}"
echo "=========================================================="

mkdir -p "$OUTPUT_DIR"
mkdir -p work

python -u probe_qwen_generation.py \
  --model_name       "$MODEL_NAME"       \
  --n_disks          "$N_DISKS"          \
  --generated_texts  "$GENERATED_TEXTS"  \
  --layers           "$LAYERS"           \
  --output_dir       "$OUTPUT_DIR"       \
  --device           "$DEVICE"           \
  --dtype            "$DTYPE"            \
  --epochs           "$EPOCHS"           \
  --lr               "$LR"              \
  --seed             "$SEED"

echo "DeepSeek-R1-Qwen32B generation probe completed."
